<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Calculator" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/primary_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/success_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Window background and status bar -->
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:navigationBarColor">@color/bg_main</item>
    </style>
</resources>
